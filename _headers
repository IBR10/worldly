# Cloudflare Pages/Workers headers.
# No build step = no hashed filenames, so code/data get short browser caching
# (the edge cache self-invalidates on each atomic deployment).

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' https://flagcdn.com https://commons.wikimedia.org https://upload.wikimedia.org https://*.clarity.ms; frame-src https://www.youtube-nocookie.com; style-src 'self'; script-src 'self' https://www.clarity.ms https://scripts.clarity.ms; connect-src 'self' https://*.clarity.ms https://flagcdn.com https://commons.wikimedia.org https://upload.wikimedia.org; worker-src 'self'

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/css/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/assets/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
