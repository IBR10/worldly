{
  "name": "worldly",
  "version": "1.0.0",
  "private": true,
  "description": "Worldly — a geography & cultural-awareness learning game (capitals, languages, religions, US & Mexican states, flags) with spaced repetition, XP and achievements.",
  "type": "module",
  "scripts": {
    "start": "python3 -m http.server 8000",
    "serve": "python3 -m http.server 8000",
    "test": "node --test --test-reporter=./scripts/tdd-guard-reporter.mjs --test-reporter-destination=stdout \"tests/*.test.mjs\"",
    "test:ci": "node --test tests/*.test.mjs",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"css/**/*.css\"",
    "deploy": "wrangler pages deploy . --project-name=playworldly",
    "preview": "wrangler pages dev ."
  },
  "keywords": [
    "geography",
    "education",
    "quiz",
    "spaced-repetition",
    "game"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "stylelint": "^16.26.1",
    "wrangler": "^4.107.1"
  }
}
